@inject Microsoft.AspNetCore.Identity.UserManager<LandIt.Models.AppUser> UserManager


<!DOCTYPE html>
<html lang="en" data-theme="light">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="LandIt — Live mock interviews, ATS resume scoring, and AI question prep. Everything to land your next job." />

        <title>@ViewData["Title"] — LandIt</title>

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />


        <link rel="stylesheet" href="~/css/landit.css" asp-append-version="true" />

        

        @if (ViewData["UseBootstrap"] is true)
        {
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
            @* <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"> *@

        }

        @if (ViewData["UseIdentityStyles"] is true)
        {
            <link rel="stylesheet" href="~/css/identity.css" asp-append-version="true" />
        }
        @await RenderSectionAsync("Head", required: false)

        <script src="~/js/theme.js" asp-append-version="true"></script>
    </head>

    <body>

        <!--Toast Meaasges Placeholder-->
        <div aria-live="polite" aria-atomic="true" class="position-relative">
            <div class="toast-container position-fixed bottom-0 end-0 p-3">
                <div id="myToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            @TempData["ToastMessageSuccess"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            </div>
        </div>
       




        <nav class="landit-nav">
            <a href="/" class="landit-logo">Land<span>It</span></a>

            <div class="nav-right">
                    <!--Hide nav links on internal app pages-->
                    @if (ViewData["HideNavLinks"] is not true)
                    {
                        <div class="nav-links">
                            <a href="/#features">Features</a>
                            <a href="/#recruiters">Recruiters</a>
                            <a href="/#pricing">Pricing</a>
                        </div>
                    }

                    <!-- Dark/Light Mode-->
                        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" type="button">
                            <i class="ti ti-moon" id="themeIcon" aria-hidden="true"></i>
                        </button>

                    <!--Show Menu and Profile if the User is Logged in-->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);

                            <a href="/Account/Dashboard" class="btn-nav">Dashboard</a>

                            <a href="/Account/Profile" class="nav-avatar">
                                @if (!string.IsNullOrEmpty(currentUser?.Photo))
                                {
                                    <img src="@currentUser.Photo" alt="Profile" />
                                }
                                else
                                {
                                    <span>@currentUser?.FullName?.Substring(0, 1).ToUpper()</span>
                                }
                            </a>

                            @* <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="margin:0;padding:0;display:flex;">
                                <button type="submit" class="btn-nav">Logout</button>
                            </form> *@
                        }
                        else
                        {
                            <a href="/Account/Register" class="btn-nav">Get started</a>
                        }
            </div>
        </nav>

        <main>
            @RenderBody()
        </main>

        @if (ViewData["HideFooter"] is not true)
        {
            <footer class="landit-footer">
                <span>© @DateTime.Now.Year LandIt</span>
                <div class="footer-links">
                    <a href="/Home/privacy">Privacy</a>
                    <a href="/Home/terms">Terms</a>
                    <a href="/Home/contact">Contact</a>
                </div>
            </footer>
        }

        @if (ViewData["UseBootstrap"] is true)
        {
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        @* <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> *@

        }

        @await RenderSectionAsync("Scripts", required: false)
        <script>
            document.addEventListener("DOMContentLoaded", function () {
            var toastEl = document.getElementById('myToast');
            if (toastEl && toastEl.querySelector('.toast-body').innerText.trim() !== "") {
            var toast = new bootstrap.Toast(toastEl);
            toast.show();
            }
            });
        </script>


    </body>
 </html>
